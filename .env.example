APP_NAME=Relatório Folha API
APP_VERSION=1.0.0
API_PREFIX=/api
LOG_LEVEL=INFO

DATABASE_URL=sqlite:///banco.db
SECRET_KEY=change_me_with_a_long_random_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

REPORT_OUTPUT_DIR=generated_reports
REPORT_LOGO_PATH=
REPORT_SERVER_HOSTID=0
REPORT_MSSQL_HOST=mssql.example.internal
REPORT_DB_LIST=[{"user":"demo_user","pass":"demo_password","port":"0000","hostid":0,"mysql_banco":"demo_database"}]

REPORT_ZABBIX_HOST=zabbix.example.internal
REPORT_ZABBIX_USER=demo_user
REPORT_ZABBIX_PASS=demo_password
REPORT_ZABBIX_DB=demo_zabbix_db
REPORT_AUX_DB=demo_aux_db

REPORT_SMTP_SERVER=smtp.example.com
REPORT_SMTP_PORT=587
REPORT_SMTP_USER=demo_user@example.com
REPORT_SMTP_PASS=demo_password
REPORT_FROM_EMAIL=noreply@example.com
REPORT_EMAIL_RECIPIENTS=["email1@empresa.com","email2@empresa.com"]
REPORT_SMTP_TIMEOUT_SECONDS=20