APP_NAME=Relatorio Folha API
APP_VERSION=1.0.0
API_PREFIX=/api
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://<db_user>:<db_password>@<db_host>:5432/<db_name>
SECRET_KEY=<change_me_with_a_long_random_secret>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

AUTO_CREATE_ADMIN=false
ADMIN_USERNAME=<admin_username>
ADMIN_EMAIL=<admin_email@example.com>
ADMIN_PASSWORD=<admin_password>

REPORT_OUTPUT_DIR=generated_reports
REPORT_LOGO_PATH=
REPORT_SERVER_HOSTID=0
REPORT_MSSQL_HOST=<mssql_host_example>
REPORT_DB_LIST=[{"user":"<mysql_user>","pass":"<mysql_password>","port":"3306","hostid":0,"mysql_banco":"<mysql_database>"}]

REPORT_ZABBIX_HOST=<zabbix_host_example>
REPORT_ZABBIX_USER=<zabbix_user>
REPORT_ZABBIX_PASS=<zabbix_password>
REPORT_ZABBIX_DB=<zabbix_database>
REPORT_AUX_DB=<aux_database>

REPORT_SMTP_SERVER=<smtp.example.com>
REPORT_SMTP_PORT=587
REPORT_SMTP_USER=<smtp_user@example.com>
REPORT_SMTP_PASS=<smtp_password>
REPORT_FROM_EMAIL=<noreply@example.com>
REPORT_EMAIL_RECIPIENTS=["<email1@example.com>","<email2@example.com>"]
REPORT_SMTP_TIMEOUT_SECONDS=20